# Firebase Configuration (REQUIRED)
# Get these from Firebase Console: https://console.firebase.google.com/

# Database URL is NOT needed for Firebase version
# DATABASE_URL=your-database-url-here

# Session secret for Express sessions (generate a random string)
SESSION_SECRET=your-random-session-secret-here-change-this-in-production

# Firebase service account path (for backend)
# Place your serviceAccountKey.json in firebase-config/ directory
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-config/serviceAccountKey.json

# Your domain (for CORS and auth)
DOMAIN=lungiverse.com

# Node environment
NODE_ENV=production

# Optional: Port for backend server (default: 5000)
PORT=5000
